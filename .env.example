# Copy to .env.local (never commit .env.local — it is gitignored)

GEMINI_API_KEY=your_gemini_api_key

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
# Server / Vercel serverless only (IPN, payment status). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- JazzCash ---
VITE_JAZZCASH_MERCHANT_ID=your_merchant_id_here
VITE_JAZZCASH_PASSWORD=your_password_here
VITE_JAZZCASH_INTEGRITY_SALT=your_integrity_salt_here
VITE_JAZZCASH_PAYMENT_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform

# Retrieve / status inquiry API (serverless + local Express)
JAZZCASH_API_BASE_URL=https://sandbox.jazzcash.com.pk

# Optional: override MWALLET REST v2 CNIC URL (defaults in server/config.js)
# VITE_JAZZCASH_MWALLET_REST_V2_URL=https://onlinepayments.jazzcash.com.pk/payment-orchestrator/api/v2/rest/payments/m-wallet

# --- Only if API is on another host (usually leave unset on Vercel) ---
# VITE_API_BASE_URL=https://your-api.example.com
# ALLOWED_ORIGINS=https://your-site.vercel.app
