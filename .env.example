# Copy this file to .env.local and fill in your values

GEMINI_API_KEY=your_gemini_api_key

# Supabase (required for bookings & contact messages)
# Get from: Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# JazzCash (from Sandbox Credentials)
VITE_JAZZCASH_MERCHANT_ID=your_merchant_id_here
VITE_JAZZCASH_PASSWORD=your_password_here
VITE_JAZZCASH_INTEGRITY_SALT=your_integrity_salt_here
# Sandbox: https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform
VITE_JAZZCASH_PAYMENT_URL=https://sandbox.jazzcash.com.pk/CustomerPortal/transactionmanagement/merchantform

# Backend: JazzCash API for Status Inquiry (optional)
# JAZZCASH_API_BASE_URL=https://sandbox.jazzcash.com.pk
