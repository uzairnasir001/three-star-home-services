# Copy to .env.local (never commit .env.local — it is gitignored)

GEMINI_API_KEY=your_gemini_api_key

# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- JazzCash MWALLET REST v2.0 (with CNIC) — merchant guide ---
VITE_JAZZCASH_MERCHANT_ID=
VITE_JAZZCASH_PASSWORD=
VITE_JAZZCASH_INTEGRITY_SALT=
# Server: pp_Amount = PKR × 100; IPN / retrieve: divide pp_Amount by 100 for PKR.

JAZZCASH_API_BASE_URL=https://sandbox.jazzcash.com.pk

# Debug MWALLET outbound — logs + API `outboundPayload` include real pp_Password (restart local server after set).
# JAZZCASH_SUPPORT_LOG=1
# JAZZCASH_LOG_OUTBOUND_PAYLOAD=1

# VITE_JAZZCASH_MWALLET_REST_V2_URL=https://onlinepayments.jazzcash.com.pk/payment-orchestrator/api/v2/rest/payments/m-wallet

# VITE_API_BASE_URL=
# ALLOWED_ORIGINS=
